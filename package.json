{
  "name": "selfhosted-mobile",
  "main": "expo-router/entry",
  "version": "0.4.2",
  "scripts": {
    "start": "APP_VARIANT=development expo start",
    "start:metro-clean": "APP_VARIANT=development expo start -c",
    "android": "APP_VARIANT=development bun run prebuild && expo run:android",
    "android:preview": "APP_VARIANT=preview bun run prebuild && expo run:android --variant release",
    "android:prod": "APP_VARIANT=production bun run prebuild && expo run:android --variant release",
    "ios": "APP_VARIANT=development bun run prebuild && expo run:ios",
    "web": "APP_VARIANT=development expo start --web",
    "lint": "expo lint",
    "android:eas-dev": "eas build --local --profile development --platform android",
    "android:eas-preview": "eas build --local --profile preview --platform android",
    "android:eas-prod": "eas build --local --profile production --platform android",
    "prebuild": "expo prebuild --clean",
    "typecheck": "tsc --noEmit",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "gen:schema": "tsx scripts/generate-schema.ts"
  },
  "dependencies": {
    "@dev-plugins/react-query": "^0.4.0",
    "@expo/ui": "~55.0.6",
    "@lingui/core": "^5.9.3",
    "@lingui/react": "^5.9.3",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/material-top-tabs": "^7.4.23",
    "@react-navigation/native": "^7.1.28",
    "@tanstack/query-async-storage-persister": "^5.95.2",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@valibot/to-json-schema": "^1.6.0",
    "expo": "~55.0.9",
    "expo-application": "~55.0.10",
    "expo-blur": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-device": "~55.0.10",
    "expo-file-system": "~55.0.14",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-intent-launcher": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-network": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-sharing": "~55.0.16",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "stan-js": "^1.9.1",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^5.9.3",
    "@lingui/cli": "^5.9.3",
    "@lingui/metro-transformer": "^5.9.3",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@types/bun": "^1.3.11",
    "@types/react": "~19.2.2",
    "babel-plugin-macros": "^3.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lingui": "^0.11.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
